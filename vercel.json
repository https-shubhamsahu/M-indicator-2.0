{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "framework": null,
    "routes": [
        {
            "src": "/upcoming",
            "dest": "/upcoming.html"
        },
        {
            "src": "/news",
            "dest": "/news.html"
        },
        {
            "src": "/resumedb",
            "dest": "/resumedb.html"
        },
        {
            "src": "/ad",
            "dest": "/ad.html"
        },
        {
            "src": "/contact",
            "dest": "/contact.html"
        },
        {
            "src": "/terms",
            "dest": "/terms.html"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/404.html",
            "status": 404
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "SAMEORIGIN"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ]
}